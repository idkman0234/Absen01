<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Absen Karyawan</title>
    <script defer src="https://cdn.jsdelivr.net/npm/face-api.js@0.22.2/dist/face-api.min.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-app-compat.js"></script>
    <script src="https://www.gstatic.com/firebasejs/10.8.1/firebase-firestore-compat.js"></script>
    <style>
        body { font-family: Arial, sans-serif; text-align: center; padding: 20px; background-color: #f4f4f9; }
        #app-container { max-width: 400px; margin: auto; background: white; padding: 20px; border-radius: 15px; box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
        #status { margin-bottom: 20px; font-weight: bold; padding: 15px; border-radius: 8px; font-size: 14px; }
        .info { background-color: #d1ecf1; color: #0c5460; }
        .loading { background-color: #fff3cd; color: #856404; }
        .success { background-color: #d4edda; color: #155724; }
        .error { background-color: #f8d7da; color: #721c24; }
        
        #camera-container { position: relative; margin: 20px auto; width: 100%; max-width: 320px; min-height: 240px; display: none; }
        video, canvas { position: absolute; top: 0; left: 0; width: 100%; height: 100%; object-fit: cover; border-radius: 12px; transform: scaleX(-1); }
        video { position: relative; z-index: 1; border: 4px solid #fff; box-shadow: 0 4px 10px rgba(0,0,0,0.2); }
        canvas { z-index: 2; }
        
        .btn-grup { display: flex; gap: 10px; }
        button { padding: 15px 10px; font-size: 16px; cursor: pointer; border-radius: 8px; border: none; color: white; width: 100%; font-weight: bold; }
        .btn-masuk { background-color: #28a745; }
        .btn-keluar { background-color: #dc3545; }
    </style>
</head>
<body>
    <div id="app-container">
        <h2>Absensi Restoran</h2>
        <div id="status" class="info">Silakan pilih jenis absensi hari ini.</div>
        
        <div class="btn-grup" id="grup-tombol">
            <button class="btn-masuk" onclick="mulaiProsesAbsen('Masuk')">📍 Masuk Kerja</button>
            <button class="btn-keluar" onclick="mulaiProsesAbsen('Keluar')">📍 Selesai / Pulang</button>
        </div>

        <div id="camera-container">
            <video id="video" autoplay muted playsinline disablePictureInPicture></video>
            <canvas id="overlay"></canvas>
        </div>
    </div>

    <script>
        const firebaseConfig = {
            apiKey: "AIzaSyAvecIxfnR-7VJgJJL7LDCvTUZuTpYLRz8",
            authDomain: "absen-cabang-d6f37.firebaseapp.com",
            projectId: "absen-cabang-d6f37",
            storageBucket: "absen-cabang-d6f37.firebasestorage.app",
            messagingSenderId: "464663936990",
            appId: "1:464663936990:web:12af760625813c83d0274f"
        };
        firebase.initializeApp(firebaseConfig);
        const db = firebase.firestore();

        const MODEL_URL = 'https://cdn.jsdelivr.net/gh/justadudewhohacks/face-api.js@master/weights';
        let video = document.getElementById('video');
        let statusDiv = document.getElementById('status');
        let faceMatcher = null; 
        let absenSelesai = false;
        let jenisAbsenSaatIni = ""; 

        function mulaiProsesAbsen(jenis) {
            jenisAbsenSaatIni = jenis;
            document.getElementById('grup-tombol').style.display = 'none';
            nyalakanKameraDanAI();
        }

        async function nyalakanKameraDanAI() {
            statusDiv.innerText = `Memuat AI untuk Absen ${jenisAbsenSaatIni}...`;
            statusDiv.className = "loading";
            try {
                await faceapi.nets.tinyFaceDetector.loadFromUri(MODEL_URL);
                await faceapi.nets.faceLandmark68Net.loadFromUri(MODEL_URL);
                await faceapi.nets.faceRecognitionNet.loadFromUri(MODEL_URL);
                
                const snapshot = await db.collection("data_wajah").get();
                let daftarWajahKaryawan = [];
                snapshot.forEach(doc => {
                    const data = doc.data();
                    daftarWajahKaryawan.push(new faceapi.LabeledFaceDescriptors(data.nama, [new Float32Array(data.descriptor)]));
                });

                if (daftarWajahKaryawan.length > 0) faceMatcher = new faceapi.FaceMatcher(daftarWajahKaryawan, 0.68);

                // PENINGKATAN KODE KAMERA AGAR TIDAK BLACK SCREEN
                const stream = await navigator.mediaDevices.getUserMedia({ 
                    video: { 
                        facingMode: 'user',
                        width: { ideal: 640 },
                        height: { ideal: 480 }
                    } 
                });
                
                video.srcObject = stream;
                
                // Paksa atribut video lewat Javascript (Bypass strict mode mobile browser)
                video.setAttribute('autoplay', '');
                video.setAttribute('muted', '');
                video.setAttribute('playsinline', '');

                document.getElementById('camera-container').style.display = 'block';
                
                video.onloadedmetadata = () => {
                    // Pastikan video benar-benar di-play sebelum AI jalan
                    video.play().then(() => {
                        statusDiv.innerText = "Arahkan wajah Anda ke layar...";
                        statusDiv.className = "info";
                        mulaiAutoScan();
                    }).catch(e => {
                        console.error("Gagal auto-play video:", e);
                        statusDiv.innerText = "Klik pada layar video untuk menyalakan kamera.";
                    });
                };
            } catch (err) {
                statusDiv.innerText = "Error kamera/AI! Pastikan browser diizinkan mengakses kamera.";
                statusDiv.className = "error";
                console.error("Detail Error:", err);
            }
        }

        function mulaiAutoScan() {
            const canvas = document.getElementById('overlay');
            const displaySize = { width: video.videoWidth, height: video.videoHeight };
            faceapi.matchDimensions(canvas, displaySize);

            const interval = setInterval(async () => {
                if (absenSelesai) { clearInterval(interval); return; }

                const deteksiLive = await faceapi.detectSingleFace(video, new faceapi.TinyFaceDetectorOptions()).withFaceLandmarks().withFaceDescriptor();
                canvas.getContext('2d').clearRect(0, 0, canvas.width, canvas.height);

                if (deteksiLive) {
                    const resizedDetections = faceapi.resizeResults(deteksiLive, displaySize);
                    faceapi.draw.drawDetections(canvas, resizedDetections);

                    if (!faceMatcher) return;

                    const hasilPencocokan = faceMatcher.findBestMatch(deteksiLive.descriptor);
                    
                    if (hasilPencocokan.label !== 'unknown') {
                        absenSelesai = true;
                        const namaKaryawan = hasilPencocokan.label;

                        await db.collection("log_absen").add({
                            nama: namaKaryawan,
                            waktu: new Date(),
                            status: jenisAbsenSaatIni 
                        });

                        statusDiv.innerText = `✅ SUKSES! Halo ${namaKaryawan}, absen ${jenisAbsenSaatIni} tercatat.`;
                        statusDiv.className = "success";
                        
                        const drawBox = new faceapi.draw.DrawBox(resizedDetections.detection.box, { label: namaKaryawan, boxColor: 'green' });
                        drawBox.draw(canvas);
                        video.srcObject.getTracks().forEach(track => track.stop());
                    } else {
                        statusDiv.innerText = "❌ Wajah Tidak Dikenali!";
                        statusDiv.className = "error";
                    }
                }
            }, 500);
        }
    </script>
</body>
</html>
